{
    "name": "@donecollectively/stellar-contracts",
    "version": "0.9.5-beta.1",
    "description": "Smart contract fusion for Cardano (BETA!)",
    "license": "SEE LICENSE IN LICENSE.TXT",
    "main": "./dist/stellar-contracts.mjs",
    "types": "./dist/stellar-contracts.d.ts",
    "engines": {
        "node": ">=20"
    },
    "bin": {
        "stellog": "./dist/stellog-cli-node.mjs",
        "stellar-release": "./scripts/release"
    },
    "exports": {
        ".": {
            "typescriptNative": "./index.ts",
            "types": "./dist/stellar-contracts.d.ts",
            "import": "./dist/stellar-contracts.mjs"
        },
        "./contracts/*": {
            "import": "./dist/contracts/*.mjs",
            "default": "./dist/contracts/*.mjs"
        },
        "./testing": {
            "types": "./dist/testing.d.ts",
            "node": "./dist/testing-node.mjs",
            "import": "./dist/testing-browser.mjs"
        },
        "./rollup-plugins": {
            "types": "./dist/rollup-plugins.d.ts",
            "import": "./dist/rollup-plugins.mjs"
        },
        "./HeliosProgramWithCacheAPI": {
            "types": "./dist/HeliosProgramWithCacheAPI.d.ts",
            "node": "./dist/HeliosProgramWithFSCache.mjs",
            "import": "./dist/HeliosProgramWithMockCacheAPI.mjs"
        },
        "./ui.css": "./dist/ui.css",
        "./ui": {
            "types": "./dist/ui.d.ts",
            "import": "./dist/ui.mjs"
        },
        "./logger": {
            "types": "./dist/types/src/loggers/stellog.d.ts",
            "import": "./dist/logger.mjs"
        }
    },
    "type": "module",
    "scripts": {
        "build": "scripts/build",
        "release": "scripts/release",
        "release:patch": "scripts/release --bump=patch",
        "release:minor": "scripts/release --bump=minor",
        "release:major": "scripts/release --bump=major",
        "release:prerelease": "scripts/release --bump=prerelease",
        "dev": "scripts/rollup --watch",
        "dev:rollupPlugin": "scripts/esbuild-rollup-dev",
        "docs:build": "tsc -p ./tsconfig.all.dts.json ; pnpm docs:generate",
        "docs:generate": "typedoc --cleanOutputDir --tsconfig tsconfig.all.dts.json index.ts --json docs/info.json --html docs/html",
        "smoke:test": "SMOKE=1 vitest run 02 04",
        "smoke:testing": "SMOKE=1 vitest --inspect --poolOptions.forks.singleFork watch 02 04",
        "test": "vitest run ",
        "testing": "vitest watch",
        "testing:debug": "vitest --inspect --poolOptions.forks.singleFork watch",
        "test:ui": "vitest --ui",
        "test:run": "vitest run"
    },
    "author": "Done Collectively LCA",
    "dependencies": {
        "@ark/json-schema": "^0.0.4",
        "@arktype/schema": "^0.54.0",
        "arktype": "^2.1.26",
        "clsx": "2.1.1",
        "dexie": "^4.2.1",
        "eventemitter3": "5.0.1",
        "nanoid": "5.1.6",
        "pino": "^10.3.0",
        "pino-pretty": "^13.1.3",
        "proper-lockfile": "4.1.2"
    },
    "peerDependencies": {
        "@cardano-ogmios/client": "^6.11.2",
        "@helios-lang/cbor": "^0.3.1",
        "@helios-lang/codec-utils": "^0.3.4",
        "@helios-lang/compiler": "^0.17.31",
        "@helios-lang/compiler-utils": "^0.5.17",
        "@helios-lang/contract-utils": "^0.3.21",
        "@helios-lang/crypto": "^0.2.3",
        "@helios-lang/ir": "^0.3.10",
        "@helios-lang/ledger": "^0.7.23",
        "@helios-lang/tx-utils": "^0.6.15",
        "@helios-lang/type-utils": "^0.3.0",
        "@helios-lang/uplc": "^0.7.20",
        "react": "^18.3",
        "react-dom": "^18.3",
        "rollup-plugin-esbuild": "^6.1.0"
    },
    "devDependencies": {
        "@helios-lang/cbor": "^0.3.1",
        "@helios-lang/codec-utils": "^0.3.4",
        "@helios-lang/compiler": "^0.17.31",
        "@helios-lang/compiler-utils": "^0.5.17",
        "@helios-lang/contract-utils": "^0.3.21",
        "@helios-lang/crypto": "^0.2.3",
        "@helios-lang/ir": "^0.3.10",
        "@helios-lang/ledger": "^0.7.23",
        "@helios-lang/tx-utils": "^0.6.15",
        "@helios-lang/type-utils": "^0.3.0",
        "@helios-lang/uplc": "^0.7.20",
        "@microsoft/api-extractor": "^7.47.11",
        "@modelcontextprotocol/sdk": "^1.24.3",
        "@rollup/plugin-image": "^3.0.3",
        "@rollup/plugin-json": "^6.0.1",
        "@rollup/plugin-node-resolve": "^15.1.0",
        "@rollup/pluginutils": "^5.0.2",
        "@svgr/rollup": "^8.1.0",
        "@types/node": "^20.2.5",
        "@types/proper-lockfile": "^4.1.4",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "esbuild": "^0.25.0",
        "fake-indexeddb": "^6.2.5",
        "magic-string": "^0.30.17",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "rollup": "^4.52.0",
        "rollup-plugin-esbuild": "^6.1.0",
        "rollup-plugin-import-css": "^4.1.2",
        "rollup-plugin-node-externals": "^6.1.1",
        "semver": ">=7.5.2",
        "tslib": "^2.5.3",
        "typedoc": "^0.28.14",
        "typedoc-plugin-markdown": "^4.9.0",
        "typescript": "5.6.2",
        "vite": "^7.1.11",
        "vitest": "^3.2.4"
    }
}
